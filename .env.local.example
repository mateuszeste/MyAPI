# ─── Claude Pro ───────────────────────────────────────────────────────────────
# Get these from https://claude.ai/settings/usage (see README for instructions)
CLAUDE_ORG_ID=your-claude-org-id
CLAUDE_SESSION_COOKIE=your-claude-session-cookie
# CLAUDE_DEVICE_ID is optional - extracted from request headers if not set
# CLAUDE_DEVICE_ID=your-claude-device-id

# ─── OpenAI (ChatGPT Codex) ───────────────────────────────────────────────────
# JSON array of account objects with a public display label plus private web-session credentials.
# Get auth_token and session_cookie from chatgpt.com (see README for instructions).
# Format: [{"label":"Personal","auth_token":"token1","session_cookie":"cookie1"},{"label":"Work","auth_token":"token2","session_cookie":"cookie2"}]
CHATGPT_ACCOUNTS=[]

# ─── OpenRouter ────────────────────────────────────────────────────────────────
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# ─── Ollama Cloud ──────────────────────────────────────────────────────────────
# Get your session cookie from https://ollama.com/settings
OLLAMA_SESSION_COOKIE=your-ollama-session-cookie

# ─── Kilo Code ──────────────────────────────────────────────────────────────────
# Get your session cookie from https://app.kilo.ai/credits (while logged in)
KILO_SESSION_COOKIE=your-kilo-session-cookie

# ─── Antigravity ───────────────────────────────────────────────────────────────
# JSON array of account objects with email, refresh_token, and optional public label.
# Emails stay server-side; labels are what the dashboard sends to the browser.
# Format: [{"label":"Personal","email":"user@example.com","refresh_token":"token1"},{"label":"Work","email":"user2@example.com","refresh_token":"token2"}]
ANTIGRAVITY_ACCOUNTS=[]
ANTIGRAVITY_PROJECT_ID=your-project-id

# Google OAuth2 credentials (now strictly required for Antigravity route!)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Get your API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-api-key

# ─── Vercel / Production Security ───────────────────────────────
# When deployed, set ADMIN_PASSWORD to protect your dashboard from unauthorized access.
# If left empty/undefined, the dashboard runs publicly without authentication.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-super-secret-password

# ─── Google One / Gemini AI Credits ────────────────────────────
# Paste the full Cookie header from one.google.com (DevTools → Network → ai/activity → Request Headers → cookie)
# Each Antigravity account has its own Gemini AI credit pool — set per-index cookies for accounts beyond [0]:
#   GOOGLE_ONE_COOKIES     → falls back for account[0]
#   GOOGLE_ONE_COOKIES_0   → explicit override for account[0]
#   GOOGLE_ONE_COOKIES_1   → cookies for account[1]
# GOOGLE_ONE_COOKIES="SID=...; HSID=...; SSID=...; APISID=...; SAPISID=...; __Secure-1PSID=...; __Secure-3PSID=..."
# GOOGLE_ONE_COOKIES_1="SID=...; HSID=...; SSID=...; APISID=...; SAPISID=...; __Secure-1PSID=...; __Secure-3PSID=..."

# ─── Antigravity (Server-side) ─────────────────────────────────────────────────
# Account tabs are populated from ANTIGRAVITY_ACCOUNTS labels.
# No client-side env var needed - emails are fetched server-side via API for privacy.

# ─── AWS / Amazon Bedrock ──────────────────────────────────────────────────────
# RECOMMENDED: IAM user credentials (never expire, work from any IP including Vercel)
# 1. AWS Console → IAM → Users → Create user (e.g. "MyAPI-Monitor")
# 2. Attach a custom policy with action: "freetier:GetAccountPlanState"
# 3. Security credentials → Create access key → Other
AWS_ACCESS_KEY_ID=your_api_key
AWS_SECRET_ACCESS_KEY=your_secret

# FALLBACK: Browser session cookie (expires, may fail on Vercel due to session expiry)
# AWS_SESSION_COOKIE=your-aws-session-cookie
